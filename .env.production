# ============================================
# 🌐 网络配置
# ============================================
# 代理前缀
VITE_APP_BASE_API = '/api'
# 网关控制面切换后启用；未配置时继续访问 base-sysadmin。
# VITE_GATEWAY_ROUTE_API_BASE=/gateway-admin/routes
# 项目名称
VITE_APP_TITLE=Opensabre开发平台
# 线上前端使用线上回调客户端。
VITE_OAUTH2_REGISTRATION_ID=base-gateway-client
# WebSocket 端点（可选）
#VITE_APP_WS_ENDPOINT=wss://api.youlai.tech/ws 

# ============================================
# 🎛️ 功能开关
# ============================================
# 多租户（需与后端 app.tenant.enabled 保持一致）
VITE_APP_TENANT_ENABLED=false

# AI 助手（系统级开关）
VITE_ENABLE_AI_ASSISTANT=true 
